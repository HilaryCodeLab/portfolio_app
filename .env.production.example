# Template for the production environment file.
#
# Copy this to .env.production ON THE PI ONLY. The real file must never be
# committed (.gitignore line 10 covers it) and never enters the Docker image
# (.dockerignore covers it) — the image is public on GHCR.
#
# Both compose substitution and the container need these, so deploys pass it
# twice:
#
#   docker compose --env-file .env.production -f docker-compose.prod.yml \
#       -p portfolio-prod up -d
#
# --env-file resolves ${DB_DATABASE} etc. in docker-compose.prod.yml itself;
# the service's env_file: entry passes them into the app container.

APP_NAME=portfolio_app
APP_ENV=production
APP_DEBUG=false

# Generate a fresh key on the Pi — do not reuse the development one:
#   docker run --rm ghcr.io/hilarycodelab/portfolio_app:latest php artisan key:generate --show
APP_KEY=

# Must be the public https:// hostname. Laravel builds password-reset links,
# signed URLs and asset paths from this; if it says http:// or an IP, those
# links point users at the Pi's LAN address.
APP_URL=https://example.com

# --- Database ---------------------------------------------------------------
# Host is the compose service name, reachable only on the internal network.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio
DB_PASSWORD=
# Used by the mysql container's healthcheck and root account. Distinct from
# DB_PASSWORD; the app never uses it.
DB_ROOT_PASSWORD=

# --- Drivers ----------------------------------------------------------------
# Sessions in the database rather than files: survives container replacement
# without depending on the storage volume, and the sessions table already
# exists in database/schema/mysql-schema.sql.
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Logging ----------------------------------------------------------------
# stderr rather than the default stack/single: container logs belong on stdout
# so `docker logs` and journald can see them, not in a file inside the volume.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Mail -------------------------------------------------------------------
# Sail's mailpit is dev-only and is not part of the production stack. Password
# reset and email verification will fail silently on `log` — set real SMTP
# credentials before relying on those features.
MAIL_MAILER=log
